---
// Pills de tecnología compartidas por Proyectos y Experiencia.
// Acepta tokens que pueden ser KEYS (p. ej. 'JAVA_SPRING_BOOT', usadas en los
// proyectos) o el propio nombre visible (p. ej. 'Angular', usado en experiencia).
// Si el token está en TAGS, la pill lleva icono; si no, se muestra solo el texto.
import CssIcon from '../icons/CssIcon.astro';
import HerokuIcon from '../icons/HerokuIcon.astro';
import HtmlIcon from '../icons/HtmlIcon.astro';
import JavaScriptIcon from '../icons/JavaScriptIcon.astro';
import PythonIcon from '../icons/PythonIcon.astro';
import VueIcon from '../icons/VueIcon.astro';
import AngularIcon from '../icons/AngularIcon.astro';
import AwsIcon from '../icons/AwsIcon.astro';
import HexagonalArquitectureIcon from '../icons/HexagonalArquitectureIcon.astro';
import JwtIcon from '../icons/JwtIcon.astro';
import PaymentGatewayIcon from '../icons/PaymentGatewayIcon.astro';
import RabbitMqIcon from '../icons/RabbitMqIcon.astro';
import ReactIcon from '../icons/ReactIcon.astro';
import SingleSpaIcon from '../icons/SingleSpaIcon.astro';
import SpringCloudConfigIcon from '../icons/SpringCloudConfigIcon.astro';
import SpringCloudGateway from '../icons/SpringCloudGateway.astro';
import SpringIcon from '../icons/SpringIcon.astro';
import TranslateIcon from '../icons/TranslateIcon.astro';
import VaultIcon from '../icons/VaultIcon.astro';
import I18nIcon from '../icons/I18nIcon.astro';

type TagType = { name: string; icon: (_props: Record<string, any>) => any };

const TAGS: Record<string, TagType> = {
	// KEYS usadas por los proyectos (i18n)
	JAVA_SPRING_BOOT: { name: 'Java Spring Boot', icon: SpringIcon },
	SINGLE_SPA: { name: 'Single-SPA', icon: SingleSpaIcon },
	ANGULAR: { name: 'Angular', icon: AngularIcon },
	REACT: { name: 'React', icon: ReactIcon },
	VUE: { name: 'Vue', icon: VueIcon },
	JAVASCRIPT: { name: 'JavaScript', icon: JavaScriptIcon },
	HTML: { name: 'HTML', icon: HtmlIcon },
	CSS: { name: 'CSS', icon: CssIcon },
	I18N_TRANSLATIONS: { name: 'Translations i18n', icon: I18nIcon },
	HEXAGONAL_ARQUITECTURE: { name: 'Hexagonal Architecture', icon: HexagonalArquitectureIcon },
	JWT: { name: 'JWT', icon: JwtIcon },
	CONFIG_SERVER: { name: 'Config Server', icon: SpringCloudConfigIcon },
	GATEWAY: { name: 'Gateway', icon: SpringCloudGateway },
	PAYMENT_GATEWAY: { name: 'Payment Gateway', icon: PaymentGatewayIcon },
	VAULT_SECRETS: { name: 'Vault Secrets', icon: VaultIcon },
	AWS_EC2: { name: 'AWS EC2', icon: AwsIcon },
	RABBIT_MQ: { name: 'Rabbit MQ (soon)', icon: RabbitMqIcon },
	CHAT_TRANSLATIONS: { name: 'Chat Translation (soon)', icon: TranslateIcon },
	PYTHON: { name: 'Python', icon: PythonIcon },
	HEROKU: { name: 'Heroku', icon: HerokuIcon },

	// Nombres visibles usados por la experiencia
	Angular: { name: 'Angular', icon: AngularIcon },
	Vue: { name: 'Vue', icon: VueIcon },
	React: { name: 'React', icon: ReactIcon },
	JavaScript: { name: 'JavaScript', icon: JavaScriptIcon },
	Python: { name: 'Python', icon: PythonIcon },
	Heroku: { name: 'Heroku', icon: HerokuIcon },
	AWS: { name: 'AWS', icon: AwsIcon },
	'Spring Boot': { name: 'Spring Boot', icon: SpringIcon },
	'Java Spring Boot': { name: 'Java Spring Boot', icon: SpringIcon },
	'Arquitectura Hexagonal': { name: 'Arquitectura Hexagonal', icon: HexagonalArquitectureIcon },
	'Hexagonal Architecture': { name: 'Hexagonal Architecture', icon: HexagonalArquitectureIcon },
};

interface Props {
	tags?: readonly string[];
	class?: string;
}
const { tags = [], class: cls = 'mt-4' } = Astro.props;
const pill =
	'flex items-center gap-1.5 rounded-full text-xs font-medium py-1 px-2.5 border border-accent/25 bg-accent-soft dark:bg-accent/10 text-accent dark:text-accent-hot';
---

{
	tags.length > 0 && (
		<ul class:list={['flex flex-wrap gap-2', cls]}>
			{tags.map((token) => {
				const tag = TAGS[token];
				return (
					<li>
						<span class={pill}>
							{tag?.icon && <tag.icon class="size-3.5" />}
							{tag ? tag.name : token}
						</span>
					</li>
				);
			})}
		</ul>
	)
}
