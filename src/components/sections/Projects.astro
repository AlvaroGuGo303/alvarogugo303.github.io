---
import SectionContainer from '@/components/sections/SectionContainer.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import TagList from '@/components/items/TagList.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { inline } from '@/i18n/inline';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const PROJECTS = t('projects'); // tipos inferidos desde i18n/ui.ts
---

<section id="projects" class="py-20 md:py-28">
	<SectionContainer class="px-4">
		<SectionHeading eyebrow={t('projects.eyebrow')} title={t('projects.title')} />

		<div class="flex flex-col gap-6 mt-12">
			{
				PROJECTS.map((project) => {
					const { image, title, alt, description, tags } = project;
					const link = 'link' in project && project.link ? project.link : undefined;
					const linkLabel = 'linkLabel' in project ? project.linkLabel : undefined;
					return (
					<article class="af-card group p-6 md:p-8">
						<h3 class="text-lg md:text-xl font-bold text-ink dark:text-white text-center text-balance">
							{title}
						</h3>

						<div class="flex flex-col md:flex-row gap-6 mt-5">
							<div
								class:list={[
									'md:w-2/5 shrink-0 overflow-hidden rounded-xl border border-black/[0.06] dark:border-white/10',
									'imageFrameClass' in project ? project.imageFrameClass : undefined,
								]}
							>
								<img
									alt={alt ?? title}
									class:list={[
										'lightbox-thumb object-cover object-top w-full h-44 md:h-full md:max-h-56 cursor-zoom-in transition duration-500 group-hover:scale-105',
										'imageClass' in project ? project.imageClass : undefined,
									]}
									loading="lazy"
									src={image}
								/>
							</div>

							<div class="flex-1">
								<TagList tags={tags} class="" />
								<p class="mt-4 af-muted text-pretty text-sm" set:html={inline(description)} />
								{link && (
									<a
										href={link}
										target="_blank"
										rel="noopener noreferrer"
										class="inline-flex items-center gap-1.5 mt-4 px-3.5 py-2 rounded-lg text-sm font-semibold af-card text-ink dark:text-white transition hover:border-accent/40 hover:text-accent dark:hover:text-accent-hot"
									>
										{linkLabel ?? link}
										<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M7 7h10v10" />
											<path d="M7 17 17 7" />
										</svg>
									</a>
								)}
							</div>
						</div>
					</article>
					);
				})
			}
		</div>
	</SectionContainer>

	<!-- Lightbox: click en una miniatura para ampliar -->
	<div
		id="lightbox"
		class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-6 cursor-zoom-out"
		role="dialog"
		aria-modal="true"
	>
		<img id="lightbox-img" class="max-h-[90vh] max-w-[92vw] rounded-xl shadow-2xl" src="" alt="" />
	</div>
</section>

<script>
	document.addEventListener('astro:page-load', () => {
		const lb = document.getElementById('lightbox');
		const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
		if (!lb || !lbImg) return;

		const open = (src: string, alt: string) => {
			lbImg.src = src;
			lbImg.alt = alt;
			lb.classList.remove('hidden');
			lb.classList.add('flex');
			document.body.style.overflow = 'hidden';
		};
		const close = () => {
			lb.classList.add('hidden');
			lb.classList.remove('flex');
			lbImg.src = '';
			document.body.style.overflow = '';
		};

		document.querySelectorAll<HTMLImageElement>('.lightbox-thumb').forEach((img) => {
			img.addEventListener('click', () => open(img.src, img.alt));
		});
		lb.addEventListener('click', close);
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') close();
		});
	});
</script>
